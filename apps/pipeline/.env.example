SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_BUCKET=docs-raw

# Direct Postgres connection (transaction pooler). Find this in Supabase
# Studio → Project Settings → Database → Connection string → "Transaction
# pooler" (port 6543). Replace [YOUR-PASSWORD] with the database password.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
